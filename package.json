{
  "name": "nearcart-inventory-backend",
  "version": "1.0.0",
  "private": true,
  "description": "NearCart Inventory backend",
  "main": "dist/src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --signal SIGTERM --watch src --ext ts --exec \"node --import tsx src/server.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:seed:catalog": "SEED_SCOPE=catalog prisma db seed",
    "translations:backfill": "node --import tsx src/scripts/backfill-translations.ts",
    "catalog:backfill": "node --import tsx src/scripts/backfill-industry-defaults.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "libretranslate-ts": "^0.5.12",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "rate-limit-redis": "^4.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "nodemon": "^3.1.14",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
